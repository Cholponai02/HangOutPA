<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HangOutPA.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HangOutPA"
    xmlns:views="clr-namespace:HangOutPA.Views.MainNavigation"
    Shell.FlyoutBehavior="Disabled"
    Title="HangOutPA">

    <TabBar>
        <ShellContent
            Title="Feed"
            Icon="folder_icon.png"
            ContentTemplate="{DataTemplate views:MainMenuPage}"
            Route="MainMenuPage"
            Shell.NavBarIsVisible="True"
            />
        <ShellContent
    Title="Groups"
    Icon="group_icon.png"
    ContentTemplate="{DataTemplate views:GroupsPage}"
    Route="MainMenuPage"
    Shell.NavBarIsVisible="True"
    />

        <ShellContent
            Title="Profile"
            Icon="account_icon.png"
            ContentTemplate="{DataTemplate views:AccountPage}"
            Shell.NavBarIsVisible="False"
            Route="AccountPage"
            />
    </TabBar>

</Shell>
