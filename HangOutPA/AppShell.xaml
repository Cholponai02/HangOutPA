<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HangOutPA.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HangOutPA"
    xmlns:views="clr-namespace:HangOutPA.Views.MainNavigation"
    Shell.FlyoutBehavior="Disabled"
    Title="HangOutPA">

    <TabBar>
        <Tab Title="Feed" Icon="folder_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:FeedPage}" />
        </Tab>

        <Tab Title="Groups" Icon="group_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:GroupsPage}" />
        </Tab>

        <Tab Title="Profile" Icon="account_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:AccountPage}" />
        </Tab>
    </TabBar>

</Shell>
