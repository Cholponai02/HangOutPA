<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HangOutPA.ViewModels"
             x:Class="HangOutPA.Views.MainNavigation.AccountPage"
             BackgroundColor="#FFF9F5" 
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="0">

            <Grid HeightRequest="180">
                <Ellipse Fill="#FFF4E6" WidthRequest="250" HeightRequest="250" 
                         HorizontalOptions="Center" VerticalOptions="Center" 
                         Margin="0,-120,0,0"/>

                <Border WidthRequest="160" HeightRequest="160" 
                        StrokeThickness="4" Stroke="#FF8C42"
                        HorizontalOptions="Center" VerticalOptions="End">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="80"/>
                    </Border.StrokeShape>
                    <Image Source="face.jpg" Aspect="AspectFill"/>
                </Border>
            </Grid>

            <VerticalStackLayout Margin="0,15,0,5" Spacing="2">
                <Label Text="Maria, 17" FontSize="28" FontAttributes="Bold" 
                       HorizontalTextAlignment="Center" TextColor="#1E293B"/>
                <Label Text="@maria_smith" FontSize="16" HorizontalTextAlignment="Center" 
                       TextColor="#FF8C42" FontAttributes="Bold"/>
            </VerticalStackLayout>

            <Border StrokeThickness="0" HeightRequest="90" Margin="10,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF8C42" Offset="0" />
                        <GradientStop Color="#FF6B2C" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#FF8C42" Offset="0,10" Radius="20" Opacity="0.3" />
                </Border.Shadow>

                <Grid ColumnDefinitions="*, 1" RowDefinitions="*, *">
                    <VerticalStackLayout Grid.RowSpan="2" VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="126" TextColor="White" FontSize="48" FontAttributes="Bold" 
                               HorizontalTextAlignment="Center" Margin="0,-10"/>
                        <Label Text="OFFLINE HOURS" TextColor="White" FontSize="12" 
                               CharacterSpacing="2" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <VerticalStackLayout Margin="20,30,20,10" Spacing="8">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="St. Stephen's Student" TextColor="#1E293B" FontAttributes="Bold"/>
                    <Label Grid.Column="1" Text="Lvl 4" TextColor="#FF8C42" FontAttributes="Bold"/>
                </Grid>
                <ProgressBar Progress="0.7" ProgressColor="#FF8C42" ScaleY="2"/>
            </VerticalStackLayout>

            <Grid Padding="0,20" RowSpacing="15" ColumnSpacing="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0" BackgroundColor="White" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05"/>
                    </Border.Shadow>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                        <Label Text="🏆" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Trophies" FontAttributes="Bold" TextColor="#1E293B" FontSize="Medium"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" BackgroundColor="White" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                        <Label Text="💳" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Wallet" FontAttributes="Bold" TextColor="#1E293B" FontSize="Medium"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" BackgroundColor="White" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle />
                    </Border.StrokeShape>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                        <Label Text="🛡️" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Safety" FontAttributes="Bold" TextColor="#1E293B" FontSize="Medium"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="White" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                        <Label Text="📊" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Activity" FontAttributes="Bold" TextColor="#1E293B" FontSize="Medium"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Button Text="Log Out" BackgroundColor="Transparent" TextColor="#FF3B30" 
                    FontAttributes="Bold" Margin="0,10,0,30"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>