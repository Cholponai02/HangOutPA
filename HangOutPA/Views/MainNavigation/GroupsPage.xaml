<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HangOutPA.ViewModels"
             x:Class="HangOutPA.Views.MainNavigation.GroupsPage"
             BackgroundColor="#F0F2F5"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:GroupsViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, *">

        <VerticalStackLayout Grid.Row="0" Padding="25,40,25,10">
            <Label Text="My Groups" FontSize="32" FontAttributes="Bold" TextColor="#1E293B"/>
            <Label Text="Coordinate your offline activities" TextColor="#64748B" FontSize="16"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <Label Text="ACTIVE GROUPS" FontAttributes="Bold" TextColor="#FF823A"/>
                <CollectionView ItemsSource="{Binding ActiveGroups}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="100, *" Margin="0,5">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer 
                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GroupsViewModel}}, Path=GoToDetailsCommand}"
                        CommandParameter="{Binding .}"/>
                                </Grid.GestureRecognizers>

                                <Border Grid.Column="0" StrokeShape="RoundRectangle 15" StrokeThickness="0">
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" WidthRequest="80" HeightRequest="80"/>
                                </Border>

                                <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" FontSize="Medium" FontAttributes="Bold" Margin="10,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="PAST EVENTS" 
       FontAttributes="Bold" 
       TextColor="#64748B" 
       FontSize="14" 
       Margin="0,10,0,10"/>

                <CollectionView ItemsSource="{Binding PastGroups}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="100, *" Margin="0,8" Opacity="0.7">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer 
                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GroupsViewModel}}, Path=GoToDetailsCommand}"
                        CommandParameter="{Binding .}"/>
                                </Grid.GestureRecognizers>

                                <Border Grid.Column="0" 
                        WidthRequest="70" 
                        HeightRequest="70" 
                        StrokeThickness="1"
                        Stroke="#CBD5E1"
                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="15"/>
                                    </Border.StrokeShape>
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Name}" 
                           FontSize="16" 
                           FontAttributes="None" 
                           TextColor="#64748B"/>
                                    <Label Text="Completed" 
                           FontSize="11" 
                           TextColor="#94A3B8"/>
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>