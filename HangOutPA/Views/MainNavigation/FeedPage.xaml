        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Padding="20,15">
            <HorizontalStackLayout Spacing="10">
                <Button Text="All" Style="{StaticResource CategoryBtnStyle}" BackgroundColor="#FF823A" TextColor="White" CommandParameter="All" Command="{Binding FilterCommand}"/>
                <Button Text="⚽ Sport" Style="{StaticResource CategoryBtnStyle}" CommandParameter="Sport" Command="{Binding FilterCommand}"/>
                <Button Text="📚 Study" Style="{StaticResource CategoryBtnStyle}" CommandParameter="Study" Command="{Binding FilterCommand}"/>
                <Button Text="🍕 Food" Style="{StaticResource CategoryBtnStyle}" CommandParameter="Food" Command="{Binding FilterCommand}"/>
            </HorizontalStackLayout>
        </ScrollView>
        <CollectionView Grid.Row="2" ItemsSource="{Binding FilteredEvents}" SelectionMode="None" >

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label Text="No events found 😢" FontSize="20" HorizontalOptions="Center"/>
                    <Label Text="Be the first to create one in this category!" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1.5" 
                Stroke="#FF8C42" 
                HeightRequest="660" 
                Margin="2,0,2,20"
                BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="30"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#FF8C42" Offset="0,10" Radius="15" Opacity="0.15"/>
                        </Border.Shadow>

                        <Grid RowDefinitions="*, Auto">

                            <Grid Grid.Row="0">
                                <Image Source="{Binding ImageSource}" Aspect="AspectFill"/>

                                <BoxView VerticalOptions="End" HeightRequest="150">
                                    <BoxView.Background>
                                        <LinearGradientBrush EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="#CC000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </BoxView.Background>
                                </BoxView>

                                <Grid ColumnDefinitions="*, Auto" 
      VerticalOptions="End" 
      Padding="20" 
      ColumnSpacing="10">

                                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Description}" 
               TextColor="White" 
               FontSize="22" 
               FontAttributes="Bold"
               LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding TimeLocation}" 
               TextColor="#E2E8F0" 
               FontSize="14"/>
                                    </VerticalStackLayout>

                                    <Border Grid.Column="1" 
            BackgroundColor="#FF3B30"
            Padding="10,6" 
            StrokeThickness="0"
            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="⚡" FontSize="12" VerticalOptions="Center"/>
                                            <Label Text="5 slots" 
                   TextColor="White" 
                   FontSize="11" 
                   FontAttributes="Bold" 
                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>
                            </Grid>

                            <Button Grid.Row="1" 
                        Text="JOIN! 🚀" 
                        Margin="15,10,15,15"
                        HeightRequest="65" 
                        FontSize="18" 
                        FontAttributes="Bold"
                        TextColor="White"
                        CornerRadius="22"
                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=GoToDetailsCommand}"
                        CommandParameter="{Binding .}">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF8C42" Offset="0"/>
                                        <GradientStop Color="#FF6B2C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>

                            <VerticalStackLayout Grid.Row="0" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,15,0" Spacing="15">
                                <ImageButton Source="heart_icon.png" WidthRequest="38" HeightRequest="38" BackgroundColor="Transparent"/>
                                <ImageButton Source="comment_icon.png" WidthRequest="38" HeightRequest="38" BackgroundColor="Transparent"
                                 Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=OpenCommentsCommand}"
                                 CommandParameter="{Binding .}"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </Grid>
    
</ContentPage>