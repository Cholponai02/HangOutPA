<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HangOutPA.ViewModels"
             x:Class="HangOutPA.Views.EventDetailsPage"
             BackgroundColor="#F3F4F6"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:EventDetailsViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" Padding="0">

        <HorizontalStackLayout Grid.Row="0" 
                               Margin="20,40,20,10" 
                               Spacing="10" 
                               VerticalOptions="Start">
            <ImageButton Source="back_icon.png" 
                         WidthRequest="25" 
                         HeightRequest="25"
                         Clicked="OnBackClicked" 
                         BackgroundColor="Transparent"/>
            <Label Text="{Binding SelectedEvent.Title, StringFormat='Inner network : {0}'}" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   VerticalOptions="Center"/>
        </HorizontalStackLayout>

        <Border Grid.Row="1" 
                Margin="20,10" 
                BackgroundColor="#DCFD8B" 
                StrokeThickness="2" 
                Stroke="#1E293B">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*, Auto" Padding="20">
                <VerticalStackLayout Grid.Column="0" Spacing="5">
                    <Label Text="CROWDFUND POT" FontAttributes="Bold" FontSize="18"/>
                    <Label Text="{Binding SelectedEvent.GoalAmount, StringFormat='GOAL: ${0}'}" FontSize="12"/>
                    <Label Text="{Binding SelectedEvent.CurrentFunded, StringFormat='FUNDED: ${0}'}" FontAttributes="Bold" TextColor="#FF823A"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="10">
                    <Border Grid.Column="1" 
        StrokeThickness="0" 
        HeightRequest="80" 
        VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>

                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF8C42" Offset="0"/>
                                <GradientStop Color="#FF6B2C" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid RowDefinitions="*, *" Padding="15,10">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ConfirmChipInCommand}"/>
                            </Grid.GestureRecognizers>

                            <Label Grid.Row="0" 
               Text="CHIP IN!" 
               TextColor="White" 
               FontSize="18" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" 
               VerticalOptions="End"/>
                            
                            <HorizontalStackLayout Grid.Row="1" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Start" 
                               Spacing="5">
                                <Label Text="Balance: €42.50" FontAttributes="Bold"
                   TextColor="White" 
                   FontSize="11" 
                   Opacity="0.9"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>

                    <HorizontalStackLayout Spacing="5">
                        <Button Text="€0" Style="{StaticResource SmallChipStyle}" 
                                Command="{Binding ChipInCommand}" CommandParameter="0"
                                IsEnabled="{Binding IsNotChippedIn}"/>
                        <Button Text="€2" Style="{StaticResource SmallChipStyle}" 
                                Command="{Binding ChipInCommand}" CommandParameter="2"
                                IsEnabled="{Binding IsNotChippedIn}"/>
                        <Button Text="€5" Style="{StaticResource SmallChipStyle}" 
                                Command="{Binding ChipInCommand}" CommandParameter="5"
                                IsEnabled="{Binding IsNotChippedIn}"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <VerticalStackLayout Grid.Row="2" Margin="0,10,0,10">
            <Label Text="OFFLINE MEMORIES" 
                   FontAttributes="Bold" 
                   TextColor="#1E293B" 
                   Margin="20,0,20,5"/>
            <Border Margin="20,0" 
                    Padding="15"
                    BackgroundColor="White" 
                    StrokeThickness="1" 
                    Stroke="#CBD5E1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto, *">
                    <Border Grid.Column="0"
                            WidthRequest="70" 
                            HeightRequest="70" 
                            BackgroundColor="#F1F5F9"
                            Margin="0,0,10,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="35"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding UploadPhotoCommand}"/>
                        </Border.GestureRecognizers>
                        <Image Source="camera_icon.png" WidthRequest="30" HeightRequest="30" Opacity="0.6"/>
                    </Border>
                    <CollectionView Grid.Column="1" ItemsSource="{Binding UploadedPhotos}" HeightRequest="75">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border WidthRequest="70" HeightRequest="70" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="15"/>
                                    </Border.StrokeShape>
                                    <Image Source="{Binding .}" Aspect="AspectFill"/>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </VerticalStackLayout>

        <CollectionView Grid.Row="3" 
                        ItemsSource="{Binding SelectedEvent.Participants}" 
                        Margin="20,10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="50, *" Margin="0,0,0,15">
                        <Border Grid.Column="0" WidthRequest="45" HeightRequest="45">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22"/>
                            </Border.StrokeShape>
                            <Image Source="{Binding Avatar}" Aspect="AspectFill" WidthRequest="45" HeightRequest="45"/>
                        </Border>
                        <Label Grid.Column="1" VerticalOptions="Center" Margin="15,0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Name}" FontAttributes="Bold" FontSize="16"/>
                                    <Span Text=" "/>
                                    <Span Text="{Binding Action}" TextColor="#64748B"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

