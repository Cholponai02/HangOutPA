        <Border Grid.Row="5" 
                BackgroundColor="White" 
                Padding="20,15,20,20" 
                VerticalOptions="End">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30,30,0,0"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="15">
                <Button Text="SPLIT THE BILL" BackgroundColor="#FF8C42" CornerRadius="30" TextColor="White" FontAttributes="Bold" Clicked="OnOpenSplitPopupClicked"/>
                <Button Text="CHECK-IN COMPLETE" 
                        HeightRequest="60" 
                        CornerRadius="30"
                        BackgroundColor="#00A86B"  
                        IsEnabled="{Binding CanCheckIn}"
                        Command="{Binding CheckInCommand}"/>
            </VerticalStackLayout>
        </Border>

    </Grid>
    
</ContentPage>